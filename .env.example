# Supabase Postgres connection string
# Get this from: Supabase project → Settings → Database → Connection string (URI)
# Replace [YOUR-PASSWORD] with the password you set when creating the project.
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-xx-xx.pooler.supabase.com:5432/postgres"

# NextAuth: generate with `openssl rand -base64 32` or any 32+ char random string
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
